# HexForge Companion — Local Development Environment (example)
# Copy to .env and fill in your actual values.
# WARNING: Never commit the real .env file.

# Riot Games API Key
# Dev: regenerates every 24h on https://developer.riotgames.com
# Personal/Production: persistent, from portal registration
RGAPI_KEY=your_riot_api_key_here

# Default region routing
# Options: americas, asia, europe
RIOT_REGION=asia

# Default platform for summoner lookups
# Options: br1, eun1, euw1, jp1, kr, la1, la2, na1, oc1, ph2, ru, sg2, th2, tr1, tw2, vn2
RIOT_PLATFORM=kr

# Production proxy (uncomment when using key backend)
# RIOT_PROXY_URL=http://localhost:8080