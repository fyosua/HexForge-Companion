{
  "identifier": "default",
  "description": "Default capabilities for HexForge Companion",
  "windows": [
    "overlay"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-open",
    "updater:default",
    "process:default",
    "process:allow-relaunch",
    "global-shortcut:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister"
  ]
}
